{
  "name": "voicetex",
  "private": true,
  "version": "1.0.0",
  "description": "Dictate math formulas with your voice and get LaTeX in real time",
  "author": "Luca Secchi <rancas@gmail.com>",
  "homepage": "https://github.com/rancas/voicetex",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch server/index.ts",
    "dev:backend:rust": "cargo run --manifest-path backend-rust/Cargo.toml",
    "dev:rust": "concurrently \"npm run dev:frontend\" \"npm run dev:backend:rust\"",
    "build": "vite build",
    "start": "node --import tsx server/index.ts",
    "electron:dev": "concurrently \"npm run dev:frontend\" \"tsx electron/main.ts\"",
    "electron:compile": "tsc -p tsconfig.server.json",
    "electron:build": "npm run build && npm run electron:compile && electron-builder --win",
    "electron:build:linux": "npm run build && npm run electron:compile && electron-builder --linux",
    "electron:build:all": "npm run build && npm run electron:compile && electron-builder --win --linux",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@xenova/transformers": "^2.17.2",
    "better-react-mathjax": "^2.3.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.0"
  }
}
